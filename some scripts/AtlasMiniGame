-- =========================
-- Game 1: Clicker (incremental)
-- =========================
local function startClicker()
	stopActiveGame()
	clearStage()

	mkStageTitle("Clicker â€” Incremental")
	mkHint("Click the big button. Buy upgrades. Try to reach goals!")

	-- display
	local displayScore = mk("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 14, 0, 68),
		Size = UDim2.new(1, -28, 0, 24),
		TextXAlignment = Enum.TextXAlignment.Left,
		Text = "Score: 0",
		Font = Enum.Font.GothamBold,
		TextSize = 16,
		TextColor3 = Color3.fromRGB(255,255,255),
	}, stage)

	-- big click button
	local btn = mk("TextButton", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.33, 0, 0.55, 0),
		Size = UDim2.new(0, 260, 0, 120),
		Text = "CLICK!",
		Font = Enum.Font.GothamBlack,
		TextSize = 34,
		TextColor3 = Color3.fromRGB(255,255,255),
		BackgroundColor3 = Color3.fromRGB(45, 70, 160),
		BorderSizePixel = 0,
	}, stage)
	mk("UICorner", { CornerRadius = UDim.new(0, 18) }, btn)

	-- upgrades panel (to the right)
	local upgradesPanel = mk("Frame", {
		Position = UDim2.new(0.58, 0, 0.35, 0),
		Size = UDim2.new(0, 220, 0, 200),
		BackgroundTransparency = 1,
	}, stage)

	local function updateDisplay()
		displayScore.Text = ("Score: %d"):format(math.floor(clickerData.score or 0))
	end

	-- helper to compute upgrade prices
	local function autoPrice(count)
		return math.floor(50 * (1.5 ^ (count or 0)))
	end
	local function powerPrice(level)
		return math.floor(30 * (1.4 ^ (level - 1)))
	end

	-- auto-clicker button
	local autoBtn = mkButton(("Auto-Clicker\nCost: %d\nOwned: %d"):format(autoPrice(clickerData.autoClickers), clickerData.autoClickers), upgradesPanel)
	autoBtn.Size = UDim2.new(1, 0, 0, 60)
	autoBtn.Position = UDim2.new(0, 0, 0, 0)
	autoBtn.TextScaled = false
	autoBtn.TextWrapped = true

	-- click power button
	local powerBtn = mkButton(("Click Power +1\nCost: %d\nPower: %d"):format(powerPrice(clickerData.clickPower), clickerData.clickPower), upgradesPanel)
	powerBtn.Size = UDim2.new(1, 0, 0, 60)
	powerBtn.Position = UDim2.new(0, 0, 0, 72)
	powerBtn.TextWrapped = true

	-- small CPS label
	local cpsLabel = mk("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 0, 0, 144),
		Size = UDim2.new(1, 0, 0, 22),
		Text = ("CPS: %.2f"):format(clickerData.cps or 0),
		Font = Enum.Font.Gotham,
		TextSize = 14,
		TextColor3 = Color3.fromRGB(240,240,240),
	}, upgradesPanel)

	-- internal state
	local stopped = false
	local fractional = 0

	-- clicking handler
	local clickConn = trackConn(btn.MouseButton1Click:Connect(function()
		if stopped then return end
		clickerData.score = (clickerData.score or 0) + (clickerData.clickPower or 1)
		updateDisplay()
		-- update text on buttons
		autoBtn.Text = ("Auto-Clicker\nCost: %d\nOwned: %d"):format(autoPrice(clickerData.autoClickers), clickerData.autoClickers)
		powerBtn.Text = ("Click Power +1\nCost: %d\nPower: %d"):format(powerPrice(clickerData.clickPower), clickerData.clickPower)
		-- quick save
		saveClickerData()
	end))

	-- buy auto-clicker
	local autoConn = trackConn(autoBtn.MouseButton1Click:Connect(function()
		local price = autoPrice(clickerData.autoClickers)
		if math.floor(clickerData.score or 0) >= price then
			clickerData.score = clickerData.score - price
			clickerData.autoClickers = (clickerData.autoClickers or 0) + 1
			-- each auto-clicker gives +1 cps (tweakable)
			clickerData.cps = (clickerData.cps or 0) + 1
			autoBtn.Text = ("Auto-Clicker\nCost: %d\nOwned: %d"):format(autoPrice(clickerData.autoClickers), clickerData.autoClickers)
			cpsLabel.Text = ("CPS: %.2f"):format(clickerData.cps or 0)
			updateDisplay()
			saveClickerData()
		end
	end))

	-- buy click power
	local powerConn = trackConn(powerBtn.MouseButton1Click:Connect(function()
		local price = powerPrice(clickerData.clickPower)
		if math.floor(clickerData.score or 0) >= price then
			clickerData.score = clickerData.score - price
			clickerData.clickPower = (clickerData.clickPower or 1) + 1
			powerBtn.Text = ("Click Power +1\nCost: %d\nPower: %d"):format(powerPrice(clickerData.clickPower), clickerData.clickPower)
			updateDisplay()
			saveClickerData()
		end
	end))

	-- passive income via RunService (fractional accumulation)
	local hbConn = trackConn(RunService.Heartbeat:Connect(function(dt)
		if stopped then return end
		-- add fractional cps
		local cps = clickerData.cps or 0
		if cps > 0 then
			fractional = fractional + cps * dt
			if fractional >= 1 then
				local add = math.floor(fractional)
				clickerData.score = (clickerData.score or 0) + add
				fractional = fractional - add
				updateDisplay()
			end
		end
	end))

	-- periodic autosave every 10 seconds
	local autosaveTimer = 0
	local autosaveConn = trackConn(RunService.Heartbeat:Connect(function(dt)
		if stopped then return end
		autosaveTimer = autosaveTimer + dt
		if autosaveTimer >= 10 then
			clickerData.lastTimestamp = os.time()
			saveClickerData()
			autosaveTimer = 0
		end
	end))

	-- expose stop
	activeGame.stop = function()
		stopped = true
		-- disconnect connections (they are tracked)
		pcall(function() clickConn:Disconnect() end)
		pcall(function() autoConn:Disconnect() end)
		pcall(function() powerConn:Disconnect() end)
		pcall(function() hbConn:Disconnect() end)
		pcall(function() autosaveConn:Disconnect() end)
		-- final save
		clickerData.lastTimestamp = os.time()
		saveClickerData()
	end

	-- initial UI refresh
	updateDisplay()
	cpsLabel.Text = ("CPS: %.2f"):format(clickerData.cps or 0)
	autoBtn.Text = ("Auto-Clicker\nCost: %d\nOwned: %d"):format(autoPrice(clickerData.autoClickers), clickerData.autoClickers)
	powerBtn.Text = ("Click Power +1\nCost: %d\nPower: %d"):format(powerPrice(clickerData.clickPower), clickerData.clickPower)
end

